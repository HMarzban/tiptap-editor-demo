# Copy to .env.local for local overrides. Vite exposes only vars prefixed with VITE_.
# VITE_APP_NAME=TipTap Editor

# Realtime collaboration (Yjs). Demo-friendly: WebRTC + public signaling when WS URL is omitted.
# VITE_COLLAB=true
# Optional: Hocuspocus-compatible WebSocket (if set, WebRTC is not used)
# VITE_COLLAB_WS_URL=wss://your-collab.example.com
# Optional: y-webrtc signaling URLs (comma-separated); defaults to y-webrtc public relay
# VITE_COLLAB_SIGNALING=wss://y-webrtc-eu.fly.dev
# VITE_COLLAB_ROOM=tiptap-demo
