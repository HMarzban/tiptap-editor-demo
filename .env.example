# Copy to .env.local for local overrides. Vite exposes only vars prefixed with VITE_.
# VITE_APP_NAME=TipTap Editor

# Realtime collaboration (Yjs). WebRTC path has no default signaling URLs (avoids dead public relays).
# VITE_COLLAB=true
#
# Optional: Hocuspocus-compatible WebSocket for doc sync (if set, WebRTC is not used)
# VITE_COLLAB_WS_URL=wss://your-collab.example.com
#
# Optional: y-webrtc signaling (comma-separated wss://). Host your own, e.g. y-webrtc-signaling behind TLS.
# VITE_COLLAB_SIGNALING=wss://your-signaling.example.com
#
# VITE_COLLAB_ROOM=tiptap-demo
